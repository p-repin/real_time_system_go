# ┌──────────────────────────────────────────────────────────────────────────┐
# │ MULTI-STAGE BUILD                                                          │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ПОЧЕМУ MULTI-STAGE:
# 1. Builder stage: Go SDK (~1GB), компилятор, инструменты
# 2. Runtime stage: только бинарник (~15MB)
#
# БЕЗ MULTI-STAGE:
#   FROM golang:1.25
#   COPY . .
#   RUN go build ...
#   → Образ ~1GB (включает весь Go SDK)
#
# С MULTI-STAGE:
#   → Образ ~20MB (только бинарник + минимальный Linux)
#
# ЭКОНОМИЯ: ~98% размера образа

# ════════════════════════════════════════════════════════════════════════════
# STAGE 1: BUILDER
# ════════════════════════════════════════════════════════════════════════════

FROM golang:1.25-alpine AS builder

# Устанавливаем зависимости для CGO (если понадобится)
# Alpine использует musl вместо glibc, поэтому нужны эти пакеты
RUN apk add --no-cache gcc musl-dev

WORKDIR /app

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ LAYER CACHING: СНАЧАЛА go.mod, ПОТОМ КОД                                   │
# └──────────────────────────────────────────────────────────────────────────┘
#
# Docker кэширует каждый слой. Если файл не изменился, слой берётся из кэша.
#
# ПОРЯДОК ВАЖЕН:
# 1. COPY go.mod go.sum → кэшируется, пока зависимости не меняются
# 2. RUN go mod download → кэшируется (зависимости уже скачаны)
# 3. COPY . . → инвалидирует кэш при ЛЮБОМ изменении кода
#
# ЕСЛИ БЫ СДЕЛАЛИ НАОБОРОТ:
#   COPY . .
#   RUN go mod download
#   → Каждое изменение кода → заново скачиваем все зависимости (~2 мин)
#
# С ПРАВИЛЬНЫМ ПОРЯДКОМ:
#   → Изменение кода → зависимости из кэша (~5 сек)

COPY go.mod go.sum ./
RUN go mod download

# Копируем весь код
COPY . .

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ BUILD FLAGS: ОПТИМИЗАЦИЯ БИНАРНИКА                                         │
# └──────────────────────────────────────────────────────────────────────────┘
#
# CGO_ENABLED=0:
#   Отключает CGO (C bindings). Создаёт статически слинкованный бинарник.
#   Без этого: бинарник зависит от glibc → не работает в scratch/alpine.
#
# -ldflags="-s -w":
#   -s: убирает symbol table (отладочная информация)
#   -w: убирает DWARF debug info
#   Экономия: ~30% размера бинарника
#
# -trimpath:
#   Убирает абсолютные пути из бинарника.
#   Безопасность: не утекают пути на build-сервере.

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -trimpath -o /app/server ./cmd/app

# ════════════════════════════════════════════════════════════════════════════
# STAGE 2: RUNTIME
# ════════════════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ ВЫБОР BASE IMAGE                                                           │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ВАРИАНТЫ:
#
# 1. scratch (пустой образ, ~0MB)
#    + Минимальный размер
#    - Нет shell, нет отладки, нет CA certificates
#    - Подходит для production без отладки
#
# 2. alpine (~5MB)
#    + Есть shell, apk, базовые утилиты
#    + Можно зайти в контейнер для отладки
#    - Чуть больше размер
#
# 3. distroless (~20MB)
#    + Минимум, но есть CA certificates
#    + Рекомендуется Google для production
#    - Нет shell
#
# Мы используем alpine для баланса: маленький + можно дебажить.

FROM alpine:3.19

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ SECURITY: NON-ROOT USER                                                    │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ПОЧЕМУ НЕ ROOT:
# Если приложение взломают (RCE), атакующий получит права root в контейнере.
# С non-root: ограниченные права, сложнее эскалировать привилегии.
#
# BEST PRACTICE: всегда запускать приложения от non-root пользователя.

# CA certificates нужны для HTTPS (подключение к внешним API)
RUN apk --no-cache add ca-certificates tzdata

# Создаём non-root пользователя
RUN addgroup -g 1000 appgroup && \
    adduser -u 1000 -G appgroup -s /bin/sh -D appuser

WORKDIR /app

# Копируем бинарник из builder stage
COPY --from=builder /app/server .

# Меняем владельца
RUN chown -R appuser:appgroup /app

# Переключаемся на non-root пользователя
USER appuser

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ HEALTHCHECK                                                                 │
# └──────────────────────────────────────────────────────────────────────────┘
#
# Docker проверяет здоровье контейнера.
# Если healthcheck падает 3 раза → контейнер помечается как unhealthy.
#
# В Kubernetes лучше использовать livenessProbe/readinessProbe,
# но для docker-compose HEALTHCHECK полезен.

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

# Порт, который слушает приложение
EXPOSE 8080

# Запуск приложения
CMD ["./server"]
